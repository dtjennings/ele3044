[Unit]
Description=Hoverscan Kiosk (Chromium)
After=graphical-session.target hoverscan-backend.service
Wants=hoverscan-backend.service

[Service]
Type=simple
ExecStart=/home/pi/hoverscan_launcher/scripts/start_kiosk.sh http://127.0.0.1:8080
Restart=on-failure
RestartSec=1

[Install]
WantedBy=default.target
